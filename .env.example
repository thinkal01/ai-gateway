# 数据库
DATABASE_PATH=./data/gateway.db

# 服务器
PORT=8080
LOG_LEVEL=info

# Mock Provider 后端地址
MOCK_PROVIDER_BASE_URL=http://localhost:9090

# 安全
API_KEY_PREFIX_LENGTH=8       # Key 前缀长度（用于查找）
API_KEY_HASH_ALGORITHM=sha256 # 哈希算法
API_KEY_SECRET_LENGTH=32      # Key 实际密钥长度（字节）

# 用量记录
USAGE_FLUSH_INTERVAL=5s       # 批量写入间隔
USAGE_FLUSH_BATCH_SIZE=100    # 每批最大条数

# CORS
CORS_ALLOWED_ORIGINS=*